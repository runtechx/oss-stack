Vagrant.configure("2") do |config|

  config.vm.box = "almalinux/10"
  config.vm.hostname = "controlador"

  # Disable shared folder
  config.vm.synced_folder ".", "/vagrant", disabled: true

  config.vm.provider "hyperv" do |h|
    h.vmname = "controlador"
    h.memory = 2048
    h.cpus = 2
    h.enable_virtualization_extensions = true
  end

  config.vm.network "private_network", type: "dhcp"

  config.vm.provision "shell", inline: <<-SHELL
    set -e

    echo "Fixing repo configuration..."

    sudo sed -i \
      -e 's/^[[:space:]]*mirrorlist=/#mirrorlist=/' \
      -e 's/^[[:space:]]*#[[:space:]]*baseurl=/baseurl=/' \
      /etc/yum.repos.d/*.repo

    echo "Cleaning DNF cache..."
    sudo dnf clean all
    sudo rm -rf /var/cache/dnf

    echo "Rebuilding cache..."
    sudo dnf makecache

    echo "Updating system..."
    sudo dnf update -y

    echo "Installing packages..."
    sudo dnf -y install epel-release
    sudo /usr/bin/crb enable
    sudo dnf -y install htop wget unzip
    sudo dnf install -y dnf-plugins-core
    sudo dnf config-manager --add-repo https://rpm.releases.hashicorp.com/RHEL/hashicorp.repo
    sudo dnf install -y terraform
  SHELL

end
